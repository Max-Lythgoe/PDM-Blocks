{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pdm/table-of-contents",
  "version": "0.1.0",
  "title": "Table Of Contents",
  "category": "pdm-blocks",
  "description": "Collapsible table of contents block that automatically generates a list of headings within the content. Provides easy navigation for long posts or pages.",
  "example": {},
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "spacing": {
      "margin": true
    },
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": true
  },
  "attributes": {
    "listStyle": {
      "type": "string",
      "default": "numbers"
    }
  },
  "usesContext": [
    "postId",
    "postType"
  ],
  "textdomain": "table-of-contents",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}