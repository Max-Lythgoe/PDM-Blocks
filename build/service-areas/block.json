{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pdm/service-areas",
  "version": "0.1.0",
  "title": "Service Areas",
  "category": "pdm-blocks",
  "icon": "location",
  "description": "Display service areas with optional county grouping.",
  "example": {},
  "keywords": [
    "service",
    "areas",
    "locations",
    "counties",
    "city pages",
    "cities"
  ],
  "attributes": {
    "showIcons": {
      "type": "boolean",
      "default": true
    },
    "markerColor": {
      "type": "string",
      "default": "#000000"
    },
    "groupByCounty": {
      "type": "boolean",
      "default": false
    },
    "linkCounties": {
      "type": "boolean",
      "default": false
    },
    "pillStyle": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "color": {
      "text": true,
      "link": true,
      "background": true
    }
  },
  "textdomain": "service-areas",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}