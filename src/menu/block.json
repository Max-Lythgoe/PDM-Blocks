{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pdm/menu",
	"version": "0.1.0",
	"title": "Menu",
	"category": "pdm-blocks",
	"description": "Menu block using the classic menu system with mobile and desktop styles.",
	"keywords": ["menu", "navigation", "nav"],
	"attributes": {
		"menuId": {
			"type": "number",
			"default": 0
		},
		"menuJustify": {
			"type": "string",
			"default": "flex-start"
		},
		"maxWidth": {
			"type": "number",
			"default": 1350
		},
		"menuRadius": {
			"type": "string",
			"default": "0px"
		},
		"submenuBackgroundColor": {
			"type": "string"
		},
		"submenuBackgroundGradient": {
			"type": "string"
		},
		"submenuHoverBackgroundColor": {
			"type": "string"
		},
		"submenuHoverBackgroundGradient": {
			"type": "string"
		},
		"submenuTextColor": {
			"type": "string"
		},
		"submenuHoverTextColor": {
			"type": "string"
		},
		"iconOpen": {
			"type": "string",
			"default": "bars"
		},
		"customIconUrlOpen": {
			"type": "string"
		},
		"iconClose": {
			"type": "string",
			"default": "xmark"
		},
		"customIconUrlClose": {
			"type": "string"
		},
		"iconSize": {
			"type": "string",
			"default": "45px"
		},
		"iconColor": {
			"type": "string",
			"default": "currentColor"
		},
		"useCustomColor": {
			"type": "boolean",
			"default": false
		},
		"mobileBreakpoint": {
			"type": "number",
			"default": 1024
		},
		"menuItemImageMaxWidth": {
			"type": "number",
			"default": 100
		},
		"mobileImageFirst": {
			"type": "boolean",
			"default": true
		}
	},
	"example": {
		"attributes": {
			"menuId": 1,
			"menuJustify": "justify-start",
			"maxWidth": 1350
		}
	},
	"supports": {
		"html": false,
		"multiple": false,
		"className": true,
		"color": {
			"link": true,
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalDefaultControls": {
				"background": false,
				"text": false
			}
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true,
				"lineHeight": true
			}
		}
	},
	"textdomain": "pdm-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}