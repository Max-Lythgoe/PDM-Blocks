	"description": "Menu block using the classic menu system with mobile and desktop styles.",
	"keywords": ["menu", "navigation", "nav"],
	"attributes": {
		"menuId": {
			"type": "number",
			"default": 0
		},
		"menuJustify": {
			"type": "string",
			"default": "flex-start"
		},
		"maxWidth": {
			"type": "number",
			"default": 1200
		},
		"menuRadius": {
			"type": "string",
			"default": "0px"
		},
		"submenuBackgroundColor": {
			"type": "string"
		},
		"submenuBackgroundGradient": {
			"type": "string"
		},
		"submenuHoverBackgroundColor": {
			"type": "string"
		},
		"submenuHoverBackgroundGradient": {
			"type": "string"
		},
		"submenuTextColor": {
			"type": "string"
		},
		"submenuHoverTextColor": {
			"type": "string"
		},
		"iconOpen": {
			"type": "string",
			"default": "bars"
		},
		"customIconUrlOpen": {
			"type": "string"
		},
		"iconClose": {
			"type": "string",
			"default": "xmark"
		},
		"customIconUrlClose": {
			"type": "string"
		},
		"iconSize": {
			"type": "number",
			"default": 45
		},
		"iconColor": {
			"type": "string",
			"default": "currentColor"
		},
		"useCustomColor": {
			"type": "boolean",
			"default": false
		},
		"mobileBreakpoint": {
			"type": "number",
			"default": 1024
		},
		"menuItemImageMaxWidth": {
			"type": "number",
			"default": 100
		},
		"mobileImageFirst": {
			"type": "boolean",
			"default": true
		}
	},
	"example": {
		"attributes": {
			"menuId": 1,
			"menuJustify": "justify-start",
			"maxWidth": 1200
		}
	},
	"supports": {
		"html": false,
		"multiple": false,
		"className": true,
		"color": {
			"link": true,
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalDefaultControls": {
				"background": false,
				"text": false
			}
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true,
				"lineHeight": true
			}
		}
	},
	"textdomain": "pdm-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}