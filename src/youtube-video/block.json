{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pdm/youtube-video",
	"version": "0.1.0",
	"title": "Youtube Video",
	"category": "pdm-blocks",
	"description": "Embed YouTube videos with custom aspect ratios, max width, and autoplay controls.",
	"example": {},
	"attributes": {
		"videoURL": {
			"type": "string",
			"default": ""
		},
		"aspectRatio": {
			"type": "string",
			"default": "16/9"
		},
		"customAspectRatio": {
			"type": "string",
			"default": ""
		},
		"videoAutoplay": {
			"type": "boolean",
			"default": false
		},
		"maxWidth": {
			"type": "number",
			"default": 800
		},
		"useFullWidth": {
			"type": "boolean",
			"default": false
		},
		"enableLightbox": {
			"type": "boolean",
			"default": false
		},
		"loadFacade": {
			"type": "boolean",
			"default": true
		},
		"thumbnailUrl": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": false,
		"spacing": {
			"margin": true
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true
	},
	"textdomain": "youtube-video",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}